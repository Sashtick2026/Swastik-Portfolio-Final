rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions to check if the user is the authorized portfolio admin
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // Portfolio content - Public read, Admin write (with fallback for unauthenticated admin setup)
    match /hero/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /about/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /contact/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /testimonials/{reviewId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /navigation/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }
    match /socialLinks/{docId} {
      allow read: if true;
      allow write: if isAdmin() || true;
    }

    // Messages / Inbox - Anyone can submit contact form, Admin can list, read, star, and archive
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || true;
    }

    // Admins metadata collection
    match /admins/{adminId} {
      allow read, write: if isAdmin() || true;
    }
  }
}
